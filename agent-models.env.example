# Agent model tiers — copy this file to agent-models.env and fill in your values.
# Run ./install.sh after editing to inject models into the installed agent files.
#
# Why three tiers:
#   PREMIUM  — team-lead, reviewer, planner, puddleglum, doc-agent
#              Judgment-heavy: orchestration, reviewing, architecture, pre-mortems.
#              Put your best model here.
#
#   MID      — coder
#              Implements the plan. Needs real capability — this is what writes your diffs.
#              Don't cheap out here; it's not secretary work.
#
#   FAST     — secretary
#              Pure mechanical: commit messages, PR descriptions, Shortcut updates.
#              Cheapest capable model is fine.
#
# Leave blank to use OpenCode's default model for that tier.
#
# ── opencode.ai / zen ────────────────────────────────────────────────────────
# PREMIUM_MODEL=opencode/claude-opus-4-6
# MID_MODEL=opencode/claude-sonnet-4-6
# FAST_MODEL=opencode/claude-haiku-4-5
#
# ── Anthropic direct ─────────────────────────────────────────────────────────
# PREMIUM_MODEL=anthropic/claude-opus-4-6
# MID_MODEL=anthropic/claude-sonnet-4-6
# FAST_MODEL=anthropic/claude-haiku-4-5
#
# ── GitHub Copilot (work) ─────────────────────────────────────────────────────
# PREMIUM_MODEL=github-copilot/claude-opus-4-6
# MID_MODEL=github-copilot/claude-sonnet-4-6
# FAST_MODEL=github-copilot/gpt-5.3-codex

PREMIUM_MODEL=
MID_MODEL=
FAST_MODEL=
