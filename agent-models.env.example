# Agent model tiers — copy this file to agent-models.env and fill in your values.
# Run ./install.sh after editing to inject models into the installed agent files.
#
# Why four tiers:
#   CRITICAL — team-lead, reviewer
#              The pipeline bookends. Cost should track consequence of failure, not
#              complexity of task. Team-lead mistakes cascade downstream; reviewer
#              mistakes ship. Use your best model here.
#
#   PREMIUM  — planner, puddleglum, doc-agent
#              Judgment-heavy but recoverable. Architecture mistakes get caught by
#              reviewer. Pre-mortems and docs have no failure mode that ships code.
#
#   MID      — coder
#              Implements the plan. Needs real capability — this is what writes your
#              diffs. Don't cheap out here; it's not secretary work.
#
#   FAST     — secretary
#              Pure mechanical: commit messages, PR descriptions, Shortcut updates.
#              Cheapest capable model is fine.
#
# Each platform has its own model format. Set only the platforms you use.
# Leave a section blank to use that platform's default model for all agents.
#
# ── OpenCode ──────────────────────────────────────────────────────────────────
# Model IDs are provider-qualified (e.g., github-copilot/claude-opus-4.6)
#
OPENCODE_CRITICAL=
OPENCODE_PREMIUM=
OPENCODE_MID=
OPENCODE_FAST=
#
# ── Claude Code ───────────────────────────────────────────────────────────────
# Short model names (e.g., opus, sonnet, haiku) — Claude Code resolves to
# the current version automatically.
#
CLAUDE_CODE_CRITICAL=
CLAUDE_CODE_PREMIUM=
CLAUDE_CODE_MID=
CLAUDE_CODE_FAST=
#
# ── Hermes ────────────────────────────────────────────────────────────────────
# Provider-qualified model IDs (e.g., anthropic/claude-opus-4, copilot/claude-opus-4.6)
#
HERMES_CRITICAL=
HERMES_PREMIUM=
HERMES_MID=
HERMES_FAST=
