# Agent model tiers — copy this file to agent-models.env and fill in your values.
# Run ./install.sh after editing to inject models into the installed agent files.
#
# Why three tiers:
#   PREMIUM  — team-lead, reviewer, planner, puddleglum, doc-agent
#              Judgment-heavy: orchestration, reviewing, architecture, pre-mortems.
#              Put your best model here.
#
#   MID      — coder
#              Implements the plan. Needs real capability — this is what writes your diffs.
#              Don't cheap out here; it's not secretary work.
#
#   FAST     — secretary
#              Pure mechanical: commit messages, PR descriptions, Shortcut updates.
#              Cheapest capable model is fine.
#
# ── Provider selection ────────────────────────────────────────────────────────
#
# Set AGENT_PROVIDER to select which model block to use.
# Supported: github-copilot, anthropic, opencode
#
# If AGENT_PROVIDER is not set, falls back to PREMIUM_MODEL / MID_MODEL / FAST_MODEL
# directly (backward compatible with the old format).
#
# AGENT_PROVIDER=github-copilot
#
# ── GitHub Copilot (work) ─────────────────────────────────────────────────────
# GITHUB_COPILOT_PREMIUM=github-copilot/claude-opus-4.6
# GITHUB_COPILOT_MID=github-copilot/claude-sonnet-4.5
# GITHUB_COPILOT_FAST=github-copilot/claude-haiku-4.5
#
# ── Anthropic direct (Claude Code) ───────────────────────────────────────────
# ANTHROPIC_PREMIUM=claude-opus-4-2025-05-14
# ANTHROPIC_MID=claude-sonnet-4-2025-05-14
# ANTHROPIC_FAST=claude-haiku-4-5-20250414
#
# ── opencode.ai / zen ────────────────────────────────────────────────────────
# OPENCODE_PREMIUM=opencode/claude-opus-4-6
# OPENCODE_MID=opencode/claude-sonnet-4-6
# OPENCODE_FAST=opencode/claude-haiku-4-5
#
# ── Legacy format (backward compatible) ──────────────────────────────────────
# Leave AGENT_PROVIDER unset and use these directly:
#
PREMIUM_MODEL=
MID_MODEL=
FAST_MODEL=
